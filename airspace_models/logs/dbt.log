[0m08:16:14.214650 [debug] [Thread-3 (]: On model.airspace_models.tail_delay_lineage: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "airspace_models", "target_name": "dev", "node_id": "model.airspace_models.tail_delay_lineage"} */


  create or replace view `airspace-platform`.`airspace_raw`.`tail_delay_lineage`
  OPTIONS()
  as with base as (
    select
        fl_date,
        op_unique_carrier,
        tail_num,
        origin,
        dest,
        dep_delay,
        arr_delay,
        carrier_delay,
        weather_delay,
        nas_delay,
        cancelled,
        cancellationcode
    from `airspace-platform`.`airspace_raw`.`flights_raw`
    where tail_num is not null
),

with_lineage as (
    select
        *,

        -- The previous flight's arrival delay for this same aircraft
        lag(arr_delay) over (
            partition by tail_num
            order by fl_date
        ) as prev_flight_arr_delay,

        -- Which airport this aircraft just came from
        lag(origin) over (
            partition by tail_num
            order by fl_date
        ) as prev_flight_origin,

        -- How much of today's departure delay was inherited
        case
            when dep_delay > 0 and lag(arr_delay) over (
                partition by tail_num
                order by fl_date
            ) > 0
            then least(dep_delay, lag(arr_delay) over (
                partition by tail_num
                order by fl_date
            ))
            else 0
        end as inherited_delay_minutes,

        -- Root cause classification
        case
            when cancelled = '1' and cancellationcode = 'A' then 'carrier_cancellation'
            when cancelled = '1' and cancellationcode = 'B' then 'weather_cancellation'
            when cancelled = '1' and cancellationcode = 'C' then 'nas_cancellation'
            when carrier_delay > 0 and (weather_delay is null or weather_delay = 0)
                then 'carrier_controlled'
            when weather_delay > 0 and (carrier_delay is null or carrier_delay = 0)
                then 'weather_controlled'
            when nas_delay > 0 and (carrier_delay is null or carrier_delay = 0)
                then 'faa_controlled'
            when carrier_delay > 0 and weather_delay > 0
                then 'mixed_carrier_weather'
            else 'unknown'
        end as delay_root_cause

    from base
)

select * from with_lineage;


